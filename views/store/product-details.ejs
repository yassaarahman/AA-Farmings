<%- include('../partials/head') %>
<body>
  <%- include('../partials/storeNav') %>
  <main
    class="min-h-screen bg-linear-to-br from-red-50 via-white to-pink-50 pt-12 px-6"
  >
    <div class="max-w-6xl mx-auto">
      <!-- Main Card -->
      <div class="bg-white rounded-3xl shadow-2xl overflow-hidden">
        <div class="grid grid-cols-1 lg:grid-cols-2">
          <div class="p-8 flex items-center justify-center bg-gray-100">
            <img
              src="<%= product.imageUrl %>"
              alt="<%= product.Name %>"
              class="w-full max-w-md h-125 object-cover rounded-2xl shadow-lg transition duration-500 hover:scale-105"
            />
          </div>
          <div class="p-10 flex flex-col justify-between">
            <div>
              <h2 class="text-4xl font-bold uppercase text-gray-800 mb-6"></h2>
              <div class="mb-8">
                <p class="text-gray-500 uppercase text-lg font-medium">
                  Price:
                </p>
                <p class="text-4xl font-medium text-red-500 mt-2">
                  Rs <%= product.Price %>/-
                </p>
              </div>
              <div class="mb-8">
                <p class="text-gray-500 uppercase text-lg font-medium mb-3">
                  Customer Rating:
                </p>
                <div class="flex items-center space-x-3">
                  <div class="flex text-yellow-400 text-2xl">★★★★★</div>
                  <span
                    class="bg-green-100 text-green-700 px-3 py-1 rounded-full font-semibold"
                  >
                    <%= product.Rating %>/5
                  </span>
                </div>
              </div>
              <div>
                <h3 class="text-2xl font-semibold text-gray-800 mb-3">
                  Description
                </h3>
                <p class="text-gray-600 leading-8">
                  <%= product.description %>
                </p>
              </div>
            </div>
            <!-- Buttons -->
            <div class="mt-10 flex justify-center">
              <form action="/cart" method="post">
                <button
                  type="submit"
                  class="flex-1 text-center hover:bg-green-600 text-black p-4 rounded-xl text-lg font-semibold transition duration-300 shadow-xl hover:text-white cursor-pointer"
                >
                  Add to Cart
                </button>
                <input
                  type="hidden"
                  name="productID"
                  value="<%= product.productID %>"
                />
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</body>
